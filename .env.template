# ===============================
# Teach Niche Environment Variables
# ===============================

# -------------------------------
# Supabase Configuration
# -------------------------------
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# -------------------------------
# Stripe Configuration
# -------------------------------
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_CLIENT_ID=your-stripe-client-id
STRIPE_REDIRECT_URI=https://your-redirect-uri.com/callback

# -------------------------------
# Frontend Configuration
# -------------------------------
FRONTEND_URL=https://teach-niche.com

# -------------------------------
# Optional Integrations
# -------------------------------
# OpenAI API Key (if using OpenAI services)
OPENAI_API_KEY=your-openai-api-key

# AWS S3 Configuration (if using S3 for storage)
S3_HOST=your-s3-host
S3_REGION=your-s3-region
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key

